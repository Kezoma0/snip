-- Core Utils
local defaultCache = {}
local function isDefault(class, prop, val)
    if not CFG.FilterDefaults then return false end
    if not defaultCache[class] then
        local ok, tmp = pcall(Instance.new, class)
        if ok and tmp then defaultCache[class] = tmp else return false end
    end
    local ok, def = pcall(function() return defaultCache[class][prop] end)
    return ok and def == val
end

local function serialize(val)
    local t = type(val)
    if t == "nil" then return "nil"
    elseif t == "boolean" then return val and "true" or "false"
    elseif t == "number" then return tostring(val)
    elseif t == "string" then return string.format("%q", val)
    elseif t == "table" then
        local s = {"{"}
        for k, v in pairs(val) do s[#s+1] = string.format("[%s]=%s,", serialize(k), serialize(v)) end
        s[#s+1] = "}"
        return table.concat(s)
    end
    local tt = typeof(val)
    if tt == "Vector3" then return string.format("Vector3.new(%s,%s,%s)", val.X, val.Y, val.Z)
    elseif tt == "CFrame" then return string.format("CFrame.new(%s)", table.concat({val:GetComponents()}, ","))
    elseif tt == "UDim2" then return string.format("UDim2.new(%s,%s,%s,%s)", val.X.Scale, val.X.Offset, val.Y.Scale, val.Y.Offset)
    elseif tt == "Color3" then return string.format("Color3.fromRGB(%d,%d,%d)", math.floor(val.R*255), math.floor(val.G*255), math.floor(val.B*255))
    elseif tt == "EnumItem" then return tostring(val)
    elseif tt == "Instance" then
        local ok, path = pcall(function() return val:GetFullName() end)
        return ok and string.format("game:GetService(%q):WaitForChild(%q)", val.Parent and val.Parent.Name or "nil", val.Name) or "nil"
    end
    return string.format("%q", tostring(val))
end

local cheatProps = {
    "Position","Size","CFrame","Transparency","CanCollide","Anchored","MaxHealth","Health",
    "Damage","FireRate","WalkSpeed","JumpPower","TeamColor","BrickColor","Material",
    "Reflectance","Massless","CollisionGroup","Enabled","Active","Velocity","RotVelocity",
    "FieldOfView","Range","Cooldown","Ammo","ClipSize","Recoil","Spread"
}

-- Remote Logger
local remoteLog = {}
if CFG.LogRemotes and hookmetamethod then
    local oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if (method == "FireServer" or method == "InvokeServer") and self.ClassName:match("Remote") then
            local args = {...}
            local ok, path = pcall(function() return self:GetFullName() end)
            table.insert(remoteLog, string.format("[%s] %s -> %s", method, ok and path or tostring(self), serialize(args)))
        end
        return oldNamecall(self, ...)
    end)
end

-- Dumper
local function startDump()
    dumpBtn.Active = false
    dumpBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    status.Text = "Initializing..."
    progBar.Size = UDim2.new(0, 0, 1, 0)

    task.spawn(function()
        local placeId = game.PlaceId
        local ts = os.date("%Y%m%d_%H%M%S")
        local dumpFile = string.format("%s/Dump_%s_%s.lua", CFG.OutDir, placeId, ts)
        local remoteFile = string.format("%s/Remotes_%s_%s.txt", CFG.OutDir, placeId, ts)

        if not isfolder(CFG.OutDir) then makefolder(CFG.OutDir) end

        local header = [[-- Game Dump | PlaceId: %s | %s
local D = {}
D.Resolve = function(path)
    local parts = path:split(".")
    local obj = game
    for _, p in parts do
        local ok, res = pcall(function() return obj:FindFirstChild(p, true) end)
        if not ok or not res then return nil end
        obj = res
    end
    return obj
end
return D
]]
        writefile(dumpFile, string.format(header, placeId, ts))

        local descendants = game:GetDescendants()
        local total = #descendants
        local count, written = 0, 0
        local buffer = {}

        for i, inst in descendants do
            count += 1
            if count % CFG.BatchSize == 0 then
                status.Text = string.format("Scanning: %d/%d (%.1f%%) | Written: %d", count, total, (count/total)*100, written)
                progBar.Size = UDim2.new(count/total, 0, 1, 0)
                task.wait()
            end

            local class = inst.ClassName
            if CFG.SkipHeavy and table.find(CFG.SkipHeavy, class) then continue end

            local ok, path = pcall(function() return inst:GetFullName() end)
            if not ok then continue end

            local isScript = class:match("Script") ~= nil
            local isRemote = class:match("Remote") ~= nil
            local props = {}

            for _, prop in cheatProps do
                local pok, val = pcall(function() return inst[prop] end)
                if pok and val ~= nil and not isDefault(class, prop, val) then
                    props[prop] = val
                end
            end

            if next(props) or isScript or isRemote then
                written += 1
                buffer[#buffer+1] = string.format('D[%q] = {Class=%q,', path, class)

                if isScript and CFG.DecompileScripts then
                    local src = "-- [NO SOURCE]"
                    if decompile then src = decompile(inst) or src
                    elseif getscriptsource then src = getscriptsource(inst) or src end
                    buffer[#buffer+1] = string.format('Source=%q,', src:gsub("\n", "\\n"))
                end

                if next(props) then
                    buffer[#buffer+1] = "Props={"
                    for k, v in props do
                        buffer[#buffer+1] = string.format("[%s]=%s,", serialize(k), serialize(v))
                    end
                    buffer[#buffer+1] = "},"
                end

                buffer[#buffer+1] = "}\n"

                if #buffer >= 50 then
                    appendfile(dumpFile, table.concat(buffer))
                    buffer = {}
                    -- Luau handles incremental GC automatically on yield. No manual step needed.
                end
            end
        end

        if #buffer > 0 then appendfile(dumpFile, table.concat(buffer)) end

        if CFG.LogRemotes and #remoteLog > 0 then
            writefile(remoteFile, table.concat(remoteLog, "\n"))
        end

        status.Text = string.format("Done. %d entries. Files saved.", written)
        progBar.Size = UDim2.new(1, 0, 1, 0)
        progBar.BackgroundColor3 = Color3.fromRGB(50, 160, 80)
        dumpBtn.Active = true
        dumpBtn.BackgroundColor3 = Color3.fromRGB(45, 105, 190)
    end)
end

dumpBtn.MouseButton1Click:Connect(startDump)
